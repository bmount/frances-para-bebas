{
  "id": "L06",
  "order": 6,
  "slug": "couleurs",
  "title": "Les couleurs",
  "es_title": "Los colores (y el acuerdo)",
  "focus": "Once palabritas para describir todo Nice — el mar, tu glace, el drapeau. Y dos reglas: van DESPUÉS del nombre y CONCUERDAN.",
  "objectives": [
    "Nombrar los colores.",
    "Ponerlos DESPUÉS del sustantivo (como en español).",
    "Hacerlos concordar: bleu/bleue, vert/verte."
  ],
  "reader": [
    {
      "t": "h3",
      "text": "La mer bleue de Nice"
    },
    {
      "t": "pair",
      "fr": "À Nice, la mer est bleue, absolument bleue, scandaleusement bleue.",
      "es": "En Niza, el mar es azul, absolutamente azul, escandalosamente azul."
    },
    {
      "t": "h3",
      "text": "La couleur va après le nom"
    },
    {
      "t": "pair",
      "fr": "Exactement comme en espagnol, la couleur va après le nom : la mer bleue, le ciel gris, la maison blanche.",
      "es": "Exactamente como en español, el color va después del nombre: el mar azul, el cielo gris, la casa blanca."
    },
    {
      "t": "h3",
      "text": "L'adjectif respecte le genre"
    },
    {
      "t": "pair",
      "fr": "L'adjectif change avec le genre : le chat noir, la nuit noire ; le vin blanc, la neige blanche.",
      "es": "El adjetivo cambia con el género: el gato negro, la noche negra; el vino blanco, la nieve blanca."
    },
    {
      "t": "h3",
      "text": "Des cognats transparents"
    },
    {
      "t": "pair",
      "fr": "Orange, violet, rose, bleu : des cognats pratiquement transparents ; tu adores déjà la moitié des couleurs françaises.",
      "es": "Naranja, violeta, rosa, azul: cognados prácticamente transparentes; ya adoras la mitad de los colores franceses."
    },
    {
      "t": "h3",
      "text": "Une glace sous le drapeau"
    },
    {
      "t": "pair",
      "fr": "Sur la Promenade, tu manges une glace rose et une glace violette sous le drapeau bleu-blanc-rouge.",
      "es": "En la Promenade, comes un helado rosa y un helado violeta bajo la bandera azul-blanca-roja."
    }
  ],
