  "sentences": [
    {"id": "L06-s01", "register": "parle", "fr": "La mer est bleue et le ciel est bleu.", "es": "El mar es azul y el cielo es azul.", "en": "The sea is blue and the sky is blue.", "voice": "emilie", "audio": "L06-s01"},
