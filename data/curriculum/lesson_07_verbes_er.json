      {"tense": "imparfait", "status": "teach", "label_es": "imperfecto (fondo)", "ex": "Avant, je parlais espagnol.", "es": "Antes hablaba español.", "en": "I used to speak Spanish.", "audio": "L07-t-imp"},
      {"tense": "futur proche", "status": "teach", "label_es": "futuro (voy a…)", "ex": "Je vais parler français à Nice.", "es": "Voy a hablar francés en Niza.", "en": "I'm going to speak French in Nice.", "audio": "L07-t-fp"},
