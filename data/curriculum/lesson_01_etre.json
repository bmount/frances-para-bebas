{
  "id": "L01",
  "order": 1,
  "slug": "etre",
  "title": "Être",
  "es_title": "El verbo « être » (ser / estar)",
  "focus": "Tu primer verbo francés — en todos los tiempos que se hablan de verdad — rodeado de palabras que ya posees del español. Cada ejemplo es una frase completa.",
  "objectives": [
    "Conjugar « être » en presente (formas habladas).",
    "Reconocer « être » en todos los tiempos que oirás en Nice.",
    "Describirte a ti y a las cosas con adjetivos cognados — y pedir con cortesía (je voudrais…)."
  ],
  "reader": [
    {
      "t": "h3",
      "text": "Un verbe pour deux"
    },
    {
      "t": "pair",
      "fr": "Le verbe « être » est le verbe le plus important du français. Il correspond à deux verbes espagnols : ser et estar.",
      "es": "El verbo « être » es el verbo más importante del francés. Corresponde a dos verbos españoles: ser y estar.",
      "en": "The verb « être » is the most important verb in French. It corresponds to two Spanish verbs: ser and estar."
    },
    {
      "t": "pair",
      "fr": "« Je suis américaine » et « je suis à Nice » utilisent le même verbe. Un seul verbe, zéro drame.",
      "es": "« Je suis américaine » y « je suis à Nice » usan el mismo verbo. Un solo verbo, cero drama.",
      "en": "« Je suis américaine » and « je suis à Nice » use the same verb. One single verb, zero drama."
    },
    {
      "t": "h3",
      "text": "« on », pas « nous »"
    },
    {
      "t": "pair",
      "fr": "À l'oral, on utilise « on » pour dire « nous ». « On est à la plage » signifie : estamos en la playa.",
      "es": "Al hablar, se utiliza « on » para decir « nosotros ». « On est à la plage » significa: estamos en la playa.",
      "en": "In speech, people use « on » to say « we ». « On est à la plage » means: we're at the beach."
    },
    {
      "t": "h3",
      "text": "« c'est », deux mots magiques"
    },
    {
      "t": "pair",
      "fr": "« C'est » signifie « es » ou « esto es ». Tu goûtes la socca et tu déclares : « c'est bon ! »",
      "es": "« C'est » significa « es » o « esto es ». Pruebas la socca y declaras: « ¡c'est bon! »",
      "en": "« C'est » means « it is » or « this is ». You taste the socca and you declare: « c'est bon! »"
    },
    {
      "t": "h3",
      "text": "Comment ça sonne"
    },
    {
      "t": "pair",
      "fr": "« suis », « es » et « est » se prononcent presque pareil : les consonnes finales sont muettes.",
      "es": "« suis », « es » y « est » se pronuncian casi igual: las consonantes finales son mudas.",
      "en": "« suis », « es » and « est » are pronounced almost the same: the final consonants are silent."
    }
  ],
