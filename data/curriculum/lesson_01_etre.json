  "sentences": [
    {"id": "L01-s01", "fr": "C'est important.", "es": "Es importante.", "en": "It's important.", "voice": "oris", "audio": "L01-s01"},
    {"id": "L01-s02", "fr": "C'est possible et c'est nécessaire.", "es": "Es posible y es necesario.", "en": "It's possible and it's necessary.", "voice": "emilie", "audio": "L01-s02"},
    {"id": "L01-s03", "fr": "Le restaurant est excellent.", "es": "El restaurante es excelente.", "en": "The restaurant is excellent.", "voice": "emilie", "audio": "L01-s03"},
    {"id": "L01-s04", "fr": "La situation est difficile.", "es": "La situación es difícil.", "en": "The situation is difficult.", "voice": "oris", "audio": "L01-s04"},
    {"id": "L01-s05", "fr": "On est à la station.", "es": "Estamos en la estación.", "en": "We're at the station.", "voice": "oris", "audio": "L01-s05"},
    {"id": "L01-s06", "fr": "Nous sommes à Nice.", "es": "Estamos en Niza.", "en": "We are in Nice.", "voice": "emilie", "audio": "L01-s06"},
    {"id": "L01-s07", "fr": "Il est très intelligent.", "es": "Él es muy inteligente.", "en": "He is very intelligent.", "voice": "oris", "audio": "L01-s07"},
    {"id": "L01-s08", "fr": "Elle est très intelligente.", "es": "Ella es muy inteligente.", "en": "She is very intelligent.", "voice": "emilie", "audio": "L01-s08"},
    {"id": "L01-s09", "self": true, "fr_m": "Je suis américain.", "fr_f": "Je suis américaine.", "es": "Soy americano / americana.", "en": "I am American.", "audio_m": "L01-s09-m", "audio_f": "L01-s09-f"},
    {"id": "L01-s10", "self": true, "fr_m": "Je suis content et je suis curieux.", "fr_f": "Je suis contente et je suis curieuse.", "es": "Estoy contento/a y soy curioso/a.", "en": "I'm happy and I'm curious.", "audio_m": "L01-s10-m", "audio_f": "L01-s10-f"},
    {"id": "L01-s11", "self": true, "fr_m": "Je suis français ? Non, je suis américain.", "fr_f": "Je suis française ? Non, je suis américaine.", "es": "¿Soy francés/a? No, soy americano/a.", "en": "Am I French? No, I'm American.", "audio_m": "L01-s11-m", "audio_f": "L01-s11-f"},
